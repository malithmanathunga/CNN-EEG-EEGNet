        "import re\n",
        "import h5py\n",
        "import numpy as np\n",
        "\n",
        "TARGET_SAMPLES = 2500\n",
        "\n",
        "X_temp, y, subject_ids = [], [], []\n",
        "\n",
        "def normalize_trial(trial, target_len):\n",
        "    trial = np.asarray(trial, dtype=np.float32)\n",
        "\n",
        "    if trial.ndim != 2:\n",
        "        raise ValueError(f\"Invalid trial shape: {trial.shape}\")\n",
        "\n",
        "    ch, n = trial.shape\n",
        "\n",
        "    if n > target_len:\n",
        "        trial = trial[:, :target_len]\n",
        "    elif n < target_len:\n",
        "        pad = np.zeros((ch, target_len - n), dtype=np.float32)\n",
        "        trial = np.concatenate([trial, pad], axis=1)\n",
        "\n",
        "    return trial\n",
        "\n",
        "\n",
        "for file in mat_files:\n",
        "    # ---- extract subject ID from filename ----\n",
        "    match = re.search(r\"sub(\\d+)\", file)\n",
        "    if match is None:\n",
        "        raise ValueError(f\"Subject ID not found in filename: {file}\")\n",
        "    subj_id = int(match.group(1))\n",
        "\n",
        "    with h5py.File(file, \"r\") as f:\n",
        "        ds = f[\"data_struct\"]\n",
        "\n",
        "        # ===================== UP =====================\n",
        "        up_data = np.array(ds[\"up\"])              # (trials, samples, channels)\n",
        "        up_data = np.transpose(up_data, (2, 1, 0)) # -> (channels, samples, trials)\n",
        "\n",
        "        for i in range(up_data.shape[2]):          # iterate over trials\n",
