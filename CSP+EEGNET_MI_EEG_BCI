        "\n",
        "# X shape: (trials, channels, samples)\n",
        "# samples = 500 → fs = 500 Hz\n",
        "\n",
        "def preprocess_eeg(X, fs=500, target_fs=100, band=(4, 40)):\n",
        "    \"\"\"\n",
        "    X: (trials, channels, samples)\n",
        "    \"\"\"\n",
        "\n",
        "    # ---------- Common Average Reference (CAR) ----------\n",
        "    X = X - X.mean(axis=1, keepdims=True)\n",
        "\n",
        "    # ---------- Bandpass filtering ----------\n",
        "    b, a = butter(4, band, btype='bandpass', fs=fs)\n",
        "    X = filtfilt(b, a, X, axis=2)\n",
        "\n",
        "    # ---------- Downsampling ----------\n",
        "    new_len = int(X.shape[2] * target_fs / fs)  # 2500 → 100\n",
        "    X = resample(X, new_len, axis=2)\n",
        "\n",
        "    # ---------- Z-score normalization ----------\n",
        "    X = (X - X.mean(axis=2, keepdims=True)) / (\n",
        "        X.std(axis=2, keepdims=True) + 1e-8\n",
        "    )\n",
        "\n",
        "    return X\n",
