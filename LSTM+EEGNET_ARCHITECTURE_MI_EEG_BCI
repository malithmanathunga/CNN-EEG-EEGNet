        "from sklearn.model_selection import train_test_split\n",
        "import numpy as np\n",
        "\n",
        "# --------------------------------------------------\n",
        "# 1. Create boolean masks based on subject IDs\n",
        "# --------------------------------------------------\n",
        "TEST_SUBJECTS = [3, 7, 12]   # example – change as needed\n",
        "\n",
        "test_mask = np.isin(subject_ids, TEST_SUBJECTS)\n",
        "trainval_mask = ~test_mask\n",
        "\n",
        "# --------------------------------------------------\n",
        "# 2. Split data: Train+Val vs Test (subject-based)\n",
        "# --------------------------------------------------\n",
        "X_test = X[test_mask]\n",
        "y_test = y[test_mask]\n",
        "\n",
        "X_trainval = X[trainval_mask]\n",
        "y_trainval = y[trainval_mask]\n",
        "subject_ids_trainval = subject_ids[trainval_mask]\n",
        "\n",
        "print(\"Subjects used for TEST:\", np.unique(subject_ids[test_mask]))\n",
        "print(\"Subjects used for TRAIN+VAL:\", np.unique(subject_ids_trainval))\n",
        "\n",
        "# --------------------------------------------------\n",
        "# 3. Train / Validation split (ONLY within train subjects)\n",
        "# --------------------------------------------------\n",
        "X_train, X_val, y_train, y_val = train_test_split(\n",
